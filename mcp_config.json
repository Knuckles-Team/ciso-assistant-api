{
  "mcpServers": {
    "ciso-assistant-api": {
      "command": "uv",
      "args": [
        "run",
        "ciso-assistant-mcp"
      ],
      "env": {
        "MCP_TOOL_MODE": "condensed",
        "ANALYTICS_METROLOGYTOOL": "True",
        "ASSETSTOOL": "True",
        "AUTH_USERSTOOL": "True",
        "CHATTOOL": "True",
        "CISO_ASSISTANT_PASSWORD": "",
        "CISO_ASSISTANT_TOKEN": "",
        "CISO_ASSISTANT_URL": "",
        "CISO_ASSISTANT_USERNAME": "",
        "COMPLIANCETOOL": "True",
        "CRQTOOL": "True",
        "CUSTOM_APITOOL": "True",
        "EBIOS_RMTOOL": "True",
        "EVIDENCETOOL": "True",
        "FRAMEWORKS_LIBRARIESTOOL": "True",
        "GOVERNANCETOOL": "True",
        "INCIDENTSTOOL": "True",
        "INTEGRATIONSTOOL": "True",
        "PRIVACYTOOL": "True",
        "RESILIENCETOOL": "True",
        "RISK_MANAGEMENTTOOL": "True",
        "SECURITY_FINDINGSTOOL": "True",
        "SETTINGSTOOL": "True",
        "TASKS_TIMELINETOOL": "True",
        "THIRD_PARTYTOOL": "True"
      }
    }
  }
}
